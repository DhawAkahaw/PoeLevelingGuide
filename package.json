{
    "name": "poe-leveling-overlay",
    "version": "1.0.9",
    "description": "Path of Exile Leveling Guide Overlay",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --win --publish never",
        "release": "electron-builder --win --publish always",
        "ship": "npm version patch && git push origin main --tags"
    },
    "devDependencies": {
        "@napi-rs/canvas": "^0.1.97",
        "electron": "^28.0.0",
        "electron-builder": "^26.8.1",
        "png-to-ico": "^3.0.1"
    },
    "dependencies": {
        "chokidar": "^3.6.0",
        "electron-updater": "^6.8.3"
    },
    "build": {
        "files": [
            "**/*",
            "!dist/**",
            "!.git/**",
            "!*.md",
            "!Reference.xml",
            "!scripts/**"
        ],
        "productName": "PoE Leveling Guide",
        "publish": {
            "provider": "github",
            "owner": "DhawAkahaw",
            "repo": "PoeLevelingGuide",
            "releaseType": "release"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "asar": true,
        "appId": "com.dhawakahaw.poeoverlay",
        "nsis": {
            "oneClick": true,
            "perMachine": false,
            "deleteAppDataOnUninstall": false
        }
    }
}
